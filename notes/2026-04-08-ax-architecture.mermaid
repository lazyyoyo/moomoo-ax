---
title: "AX 시스템 아키텍처 — auto-research 패턴 적용"
---

graph TB
    subgraph AUTORESEARCH["🔬 Karpathy auto-research 원본"]
        direction TB
        AR_PROGRAM["📋 program.md<br/><i>에이전트 행동 규칙</i><br/><b>사람이 시간 두고 개선</b>"]
        AR_TRAIN["📝 train.py<br/><i>유일한 수정 대상</i><br/>아키텍처, 옵티마이저,<br/>하이퍼파라미터"]
        AR_PREPARE["🔒 prepare.py<br/><i>수정 불가 (하네스)</i><br/>evaluate_bpb() 함수<br/>데이터 로더, 상수"]
        AR_RESULTS["📊 results.tsv<br/><i>실험 로그</i><br/>commit | val_bpb | status"]

        AR_PROGRAM --> AR_LOOP

        subgraph AR_LOOP["∞ 실험 루프 (NEVER STOP)"]
            direction TB
            AR1["1. train.py 수정"] --> AR2["2. git commit"]
            AR2 --> AR3["3. 실행 (5분 고정)"]
            AR3 --> AR4["4. val_bpb 확인"]
            AR4 --> AR_DECIDE{개선?}
            AR_DECIDE -->|"낮아짐"| AR_KEEP["✅ keep<br/>브랜치 전진"]
            AR_DECIDE -->|"같거나 높음"| AR_DISCARD["❌ discard<br/>git reset"]
            AR_DECIDE -->|"크래시"| AR_CRASH["💥 crash<br/>되돌리고 다음"]
        end

        AR_TRAIN -.->|수정| AR1
        AR_PREPARE -.->|평가| AR4
        AR_LOOP --> AR_RESULTS
    end

    subgraph AX_SYSTEM["🏗️ 우리 AX 시스템 — 2-Level 매핑"]
        direction TB

        subgraph LEVEL1["루프 1: AX 시스템 진화 (수동, 스프린트 단위)"]
            direction TB
            L1_PROGRAM["📋 스킬/에이전트 정의<br/><i>= program.md</i><br/><b>오너가 시간 두고 개선</b>"]
            L1_TRAIN["📝 프롬프트, hooks, eval 설정<br/><i>= train.py</i><br/>스프린트마다 조정"]
            L1_PREPARE["🔒 레벨 1 지표<br/><i>= prepare.py</i><br/>토큰량, 오너개입횟수,<br/>수용율, 재작업횟수"]
            L1_RESULTS["📊 스프린트 리포트<br/><i>= results.tsv</i>"]

            L1_PROGRAM --> L1_LOOP
            subgraph L1_LOOP["스프린트 루프"]
                L1_1["설정 변경"] --> L1_2["루프 2 실행"]
                L1_2 --> L1_3["레벨 1 지표 수집"]
                L1_3 --> L1_DECIDE{개선?}
                L1_DECIDE -->|"토큰↓ 개입↓"| L1_KEEP["✅ keep"]
                L1_DECIDE -->|"악화"| L1_DISCARD["❌ revert"]
            end
            L1_TRAIN -.->|수정| L1_1
            L1_PREPARE -.->|평가| L1_3
            L1_LOOP --> L1_RESULTS
        end

        subgraph LEVEL2["루프 2: 제품 결과물 개선 (자동, 기능 단위)"]
            direction TB
            L2_SPEC["📋 CPS 스펙<br/><b>오너가 던지는 유일한 입력</b>"]

            subgraph L2_CODE["코드 영역 (100% 결정적, 스킵 불가)"]
                direction TB
                L2_ORCH["🔧 오케스트레이터<br/><i>Python/Shell 스크립트</i><br/>루프 제어, 판정, 로깅"]
                L2_GATES["🔒 게이트 시스템<br/><i>= prepare.py</i>"]

                subgraph GATES_DETAIL["게이트 계층 (비용순)"]
                    G1["① 정적: lint, typecheck, format"]
                    G2["② 시각: Playwright 스크린샷 diff"]
                    G3["③ 구조: ARIA 스냅샷 비교"]
                    G4["④ Judge: 체크리스트 Yes/No 합성 점수"]
                end

                L2_LOG["📊 .harness/logs/<br/><i>= results.tsv</i><br/>iteration_N.json"]
            end

            subgraph L2_AI["AI 영역 (창의적, 비결정적)"]
                direction TB
                L2_PERSONA["🧑 페르소나 자동 도출<br/><i>CPS → JSON</i>"]
                L2_RUBRIC["📋 동적 체크리스트 생성<br/><i>고정 + 기능별</i>"]

                subgraph L2_WORKERS["멀티모델 워커"]
                    W_CLAUDE["🟣 Claude<br/>설계, 판정,<br/>재작업 프롬프트"]
                    W_CODEX["🟢 Codex<br/>코드 생성,<br/>패치"]
                    W_GEMINI["🔵 Gemini<br/>UI/비전,<br/>스크린샷 평가"]
                end

                L2_REWORK["🔄 재작업 프롬프트<br/>실패 항목 → 수정 지시"]
            end

            L2_SPEC --> L2_PERSONA
            L2_PERSONA --> L2_RUBRIC
            L2_RUBRIC --> L2_ORCH

            L2_ORCH -->|"작업 지시"| L2_WORKERS
            L2_WORKERS -->|"산출물 (JSON)"| L2_GATES
            L2_GATES --> L2_DECIDE{통과?}
            L2_DECIDE -->|"✅ pass"| L2_COMMIT["git commit<br/>브랜치 전진"]
            L2_DECIDE -->|"❌ fail"| L2_REWORK
            L2_REWORK -->|"다음 반복"| L2_ORCH
            L2_DECIDE -->|"💥 예산 초과"| L2_STOP["best scoring<br/>결과 남기고 종료"]
            L2_ORCH --> L2_LOG
        end

        L1_2 -.->|"실행"| LEVEL2
        LEVEL2 -.->|"지표 올라감"| L1_3
    end

    style AUTORESEARCH fill:#1a1a2e,stroke:#e94560,color:#fff
    style AX_SYSTEM fill:#0f3460,stroke:#16213e,color:#fff
    style LEVEL1 fill:#1a1a4e,stroke:#533483,color:#fff
    style LEVEL2 fill:#162447,stroke:#1f4068,color:#fff
    style L2_CODE fill:#0d2137,stroke:#e94560,color:#fff
    style L2_AI fill:#0d2137,stroke:#533483,color:#fff
    style AR_LOOP fill:#2d1b3d,stroke:#e94560,color:#fff
    style GATES_DETAIL fill:#0a1628,stroke:#1f4068,color:#fff
    style L2_WORKERS fill:#0a1628,stroke:#533483,color:#fff
