{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "코드 패치",
  "description": "워커가 출력하는 파일 변경사항 JSON",
  "type": "object",
  "required": ["files", "summary"],
  "properties": {
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "action", "content"],
        "properties": {
          "path": {
            "type": "string",
            "description": "프로젝트 루트 기준 상대경로"
          },
          "action": {
            "enum": ["create", "modify", "delete"],
            "description": "파일 작업 유형"
          },
          "content": {
            "type": "string",
            "description": "전체 파일 내용 (delete 시 빈 문자열)"
          }
        }
      }
    },
    "summary": {
      "type": "string",
      "description": "변경 요약 1줄"
    }
  }
}
